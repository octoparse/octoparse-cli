{
  "name": "octoparse-cli",
  "version": "0.1.10",
  "description": "Standalone Octoparse engine CLI that runs local extraction without the Electron client.",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octoparse/octoparse-cli.git"
  },
  "bugs": {
    "url": "https://github.com/octoparse/octoparse-cli/issues"
  },
  "homepage": "https://github.com/octoparse/octoparse-cli#readme",
  "files": [
    "dist",
    "schemas",
    "examples",
    "README.md",
    "SECURITY.md",
    "RUNTIME_SECURITY_NOTICE.txt"
  ],
  "bin": {
    "octoparse": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "prepack": "node scripts/prepare-engine-bundle.mjs",
    "release": "node scripts/release.mjs",
    "start": "node dist/index.js",
    "test": "npm run build && node --test --test-concurrency=1 test/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@octopus/bpmn": "1.0.4",
    "@octopus/engine": "1.0.21",
    "@puppeteer/browsers": "2.8.0",
    "@types/lodash": "^4.14.0",
    "@types/lodash-es": "4.17.12",
    "async": "^2.6.4",
    "axios": "1.8.4",
    "bpmn-moddle": "^0.14.1",
    "debug": "^2.6.9",
    "fast-xml-parser": "4.5.0",
    "iconv-lite": "0.6.3",
    "iso8601-duration": "^1.3.0",
    "jsonpath-plus": "10.3.0",
    "lodash": "4.17.21",
    "lodash-es": "4.17.21",
    "moment": "2.30.1",
    "puppeteer-core": "24.39.1",
    "puppeteer-extra": "3.3.6",
    "puppeteer-extra-plugin-block-resources": "2.4.3",
    "puppeteer-proxy": "1.0.3",
    "rebrowser-puppeteer-core": "24.8.1",
    "sax": "1.4.1",
    "setimmediate": "1.0.5",
    "uuid": "10.0.0",
    "ws": "^8.18.3",
    "xml2js": "0.4.23",
    "xmlbuilder": "15.1.1",
    "xmldom": "0.6.0",
    "xpath": "0.0.34"
  },
  "bundledDependencies": [
    "@octopus/bpmn",
    "@octopus/engine"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.14",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
